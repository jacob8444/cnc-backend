{
  "name": "cnc-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":        "tsx watch src/main.ts",
    "build":      "tsc",
    "build:ui":   "cd ../CNC && npm run build && cp -r dist ../cnc-backend/public",
    "build:all":  "npm run build:ui && npm run build",
    "start":      "node dist/main.js",
    "test":       "vitest run",
    "test:watch": "vitest",
    "coverage":   "vitest run --coverage"
  },
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "express":    "^4.19.2",
    "multer":     "^1.4.5-lts.1",
    "pino":       "^9.4.0",
    "serialport": "^12.0.0",
    "ws":         "^8.18.0",
    "zod":        "^3.23.8"
  },
  "devDependencies": {
    "@types/express":      "^4.17.21",
    "@types/multer":       "^1.4.12",
    "@types/node":         "^20.16.0",
    "@types/ws":           "^8.5.12",
    "@vitest/coverage-v8": "^4.1.8",
    "pino-pretty":         "^11.3.0",
    "tsx":                 "^4.19.1",
    "typescript":          "^5.5.4",
    "vitest":              "^4.1.8"
  }
}
